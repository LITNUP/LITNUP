{
  "name": "@alphagentic/sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for LITNUP — staking, agent operator flows, attestation verification.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.mjs",
      "require": "./dist/react.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/react.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts src/react.ts --format cjs,esm --dts --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "alphagentic",
    "agentic",
    "ai-agents",
    "ethereum",
    "base",
    "defi",
    "staking",
    "ai-trading"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/alphagentic/alphagentic.git",
    "directory": "sdk-typescript"
  },
  "homepage": "https://alphagentic.xyz/builders.html",
  "peerDependencies": {
    "viem": "^2.21.0",
    "react": ">=18.0.0",
    "wagmi": ">=2.10.0",
    "@tanstack/react-query": ">=5.0.0"
  },
  "peerDependenciesMeta": {
    "react": { "optional": true },
    "wagmi": { "optional": true },
    "@tanstack/react-query": { "optional": true }
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "viem": "^2.21.0",
    "vitest": "^1.4.0"
  }
}
