# Force consistent line endings — saves us from CRLF/LF chaos when collaborators
# work across Windows and macOS/Linux.

* text=auto eol=lf

# Source code: text, LF line endings
*.sol      text eol=lf
*.py       text eol=lf
*.ts       text eol=lf
*.js       text eol=lf
*.html     text eol=lf
*.css      text eol=lf
*.md       text eol=lf
*.json     text eol=lf
*.yaml     text eol=lf
*.yml      text eol=lf
*.toml     text eol=lf
*.txt      text eol=lf
*.xml      text eol=lf
*.svg      text eol=lf
*.graphql  text eol=lf

# Binary files
*.png      binary
*.jpg      binary
*.jpeg     binary
*.webp     binary
*.gif      binary
*.ico      binary
*.pdf      binary
*.zip      binary
*.tar.gz   binary
*.woff     binary
*.woff2    binary
*.eot      binary
*.ttf      binary
*.otf      binary
*.mp4      binary
*.webm     binary
*.mp3      binary

# Force download (don't try to merge) for large generated artifacts
contracts/out/**     -text -diff
contracts/cache/**   -text -diff

# GitHub linguist hints — exclude generated/test files from language stats
contracts/test/**    linguist-vendored=false  linguist-generated=false
contracts/lib/**     linguist-vendored
content/**           linguist-documentation
docs/**              linguist-documentation
brand/**             linguist-vendored

# Ignore archived legacy files in line counts
web/landing-page.html  linguist-generated
