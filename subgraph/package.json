{
  "name": "@alphagentic/subgraph",
  "version": "0.1.0",
  "description": "LITNUP protocol subgraph — indexes Base + Base Sepolia events into queryable entities.",
  "license": "Apache-2.0",
  "private": true,
  "scripts": {
    "codegen": "graph codegen",
    "build": "graph build",
    "deploy:sepolia": "graph deploy --node https://api.studio.thegraph.com/deploy/ alphagentic-sepolia",
    "deploy:base": "graph deploy --node https://api.studio.thegraph.com/deploy/ alphagentic-base",
    "deploy:hosted-sepolia": "graph deploy --node https://api.thegraph.com/deploy/ alphagentic/alphagentic-sepolia",
    "create-local": "graph create --node http://localhost:8020/ alphagentic-local",
    "remove-local": "graph remove --node http://localhost:8020/ alphagentic-local",
    "deploy-local": "graph deploy --node http://localhost:8020/ --ipfs http://localhost:5001 alphagentic-local",
    "test": "graph test"
  },
  "dependencies": {
    "@graphprotocol/graph-cli": "^0.98.1",
    "@graphprotocol/graph-ts": "^0.38.2"
  },
  "devDependencies": {
    "matchstick-as": "^0.6.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/alphagentic/protocol.git",
    "directory": "subgraph"
  }
}
