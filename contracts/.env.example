# ============================================================
# LITNUP contracts — env template
# Copy this file to .env and fill in the values.
# NEVER commit your real .env — it has private keys.
# ============================================================

# ---- Deployment ----
# Private key of the deployer wallet. Use a FRESH key generated for
# deployment only. Recommended: cast wallet new
DEPLOYER_PRIVATE_KEY=0x...

# ---- RPC endpoints ----
# Base Sepolia (testnet) — free via the public endpoint or Alchemy/Infura
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Base mainnet — DO NOT use until audits land + multisig is set up
BASE_RPC_URL=https://mainnet.base.org

# Local development (anvil)
LOCAL_RPC_URL=http://127.0.0.1:8545

# ---- Etherscan / Basescan verification ----
# Get a key at basescan.org/myapikey
BASESCAN_API_KEY=

# ---- Treasury / owner address ----
# The Safe multisig that will own LitnupToken + receive initial mint.
# For Sepolia testing, this can be your deployer wallet.
# For mainnet, this MUST be the 5-of-9 multisig.
TREASURY_ADDRESS=0x...

# ---- Oracle signers ----
# Comma-separated list of 9 addresses for the 5-of-9 oracle.
# Generate with: cast wallet new --json | jq -r '.address'
ORACLE_SIGNERS=0x...,0x...,0x...,0x...,0x...,0x...,0x...,0x...,0x...

# ---- Optional ----
# Gas reporting + fork tests
ETH_RPC_URL=https://mainnet.base.org
FORK_BLOCK_NUMBER=
