# Copy this file to .env and fill in. NEVER commit .env.
# Generate a fresh keypair: python scripts/gen_signer.py

# Signer for EIP-712 attestations (use a fresh test key, not your main wallet)
ORACLE_SIGNER_PRIVATE_KEY=

# Performance Oracle contract address on Base Sepolia (after deploy)
PERFORMANCE_ORACLE_ADDRESS=

# Chain ID (Base Sepolia = 84532; Base mainnet = 8453)
CHAIN_ID=84532

# RPC endpoint (free tier on Alchemy / Infura works)
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Optional — CoinGecko Pro key (free tier works for low-frequency pulls)
COINGECKO_API_KEY=

# Optional — write attestation logs to this directory
ATTESTATION_LOG_DIR=./logs
